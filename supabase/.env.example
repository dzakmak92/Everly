# Everly — Stripe webhook Edge Function secrets (TEMPLATE — safe to commit).
#
# These are SERVER-SIDE SECRETS for the `stripe-webhook` function. They are NOT
# the app's public keys (those live in the repo-root `.env.example`).
#
# Usage:
#   1. cp supabase/.env.example supabase/.env
#   2. Paste your real values into supabase/.env  (it is gitignored)
#   3. Push them to the deployed function:
#        supabase secrets set --env-file supabase/.env --project-ref ertsbomehtfotflbdndm
#
# Note: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by
# the Edge runtime — do NOT set them here.

# Stripe API key. Use sk_test_... while testing, sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Signing secret of the Stripe webhook endpoint you point at:
#   https://ertsbomehtfotflbdndm.supabase.co/functions/v1/stripe-webhook
# Found in Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
